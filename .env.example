# Canonical site URL (no trailing slash) — used for canonical, OG, and sitemap
# Match Vercel primary domain (www redirects from apex in Vercel project settings)
VITE_SITE_URL=https://www.spethial.com

# Google Analytics 4 — required for production builds (set in Vercel Production too)
# Find in GA4: Admin → Data streams → Web → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: load GA during `npm run dev` (off by default; production uses npm run build)
# VITE_GA_ENABLE_IN_DEV=true

# Optional: skip GA env check + post-build verify (CI without secrets only)
# VITE_GA_SKIP_VALIDATION=1

# Optional: skip Puppeteer prerender step (CI without Chromium)
# VITE_PRERENDER_SKIP=1

# Server-side only — never commit .env or expose keys in the client bundle.
# Music stats JSON is generated by SpethialLab analyze.py (Spotify export + Web API).
