{
  "redirects": [
    {
      "source": "/playground",
      "destination": "/lab",
      "permanent": true
    },
    {
      "source": "/playground/:path*",
      "destination": "/lab",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
