{
  "redirects": [
    {
      "source": "/playground",
      "destination": "/lab",
      "permanent": true
    },
    {
      "source": "/playground/:path*",
      "destination": "/lab",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.spethial.com" }],
      "destination": "https://spethial.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
